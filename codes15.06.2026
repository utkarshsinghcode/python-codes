# ques21
nums = [10, 25, 8, 40, 13, 6]
count_even = 0
count_odd = 0

for i in nums:
    if i % 2 == 0:
        count_even += 1
    elif i % 2 != 0:
        count_odd += 1

print(count_even)
print(count_odd)

