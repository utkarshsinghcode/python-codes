for i in range(1,n+1):
    if n % i == 0:
        print("factors:",i ) 

#ques 6
n = int(input())
count_even = 0
count_odd = 0
for i in range(1,n+1):
    if i % 2 == 0:
        count_even = count_even + 1
    elif i % 2 != 0:
        count_odd = count_odd + 1
print(count_even)
print(count_odd)
